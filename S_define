#include "sim_objects/default_trick_sys.sm"
#include "sim_objects/CivetServer.sm"
##include "bldc/include/bldc.h"
##include "bldc/httpMethods/bldc_http_handlers.h"
##include "bldc/httpMethods/handle_HTTP_GET_php.h"

class BLDCSimObject : public Trick::SimObject {
public:
    BLDC_MOTOR motor;
    BLDCSimObject() {
        ("default_data")       bldc_motor_default_data(&motor);
        ("initialization")     bldc_motor_init(&motor);
        (0.001, "derivative")  bldc_motor_deriv(&motor);
        (0.001, "integration") bldc_motor_integ(&motor);
        ("shutdown")           bldc_motor_shutdown(&motor);
    }
};

BLDCSimObject bldc_sim;

IntegLoop dyn_integloop(0.001) bldc_sim;

void create_connections() {
    dyn_integloop.getIntegrator(Runge_Kutta_4, 3);

    /* Give handlers access to live motor data */
    bldc_http_set_motor(&bldc_sim.motor);

    /* Register HTTP GET handlers */
    web.server.installHTTPGEThandler("motor/data",    &handle_HTTP_GET_motor_data);
    web.server.installHTTPGEThandler("motor/control", &handle_HTTP_GET_motor_control);

    printf("REGISTERING PHP HANDLER\n");
    web.server.installHTTPGEThandler("php", &handle_HTTP_GET_php);
}